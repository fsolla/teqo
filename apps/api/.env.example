# PostgreSQL database URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/teqo

# Redis URL for caching and rate limiting
# Format: redis://USER:PASSWORD@HOST:PORT
REDIS_URL=redis://localhost:6379

# Alchemy API key for fetching token metadata
# Get yours at: https://www.alchemy.com/
ALCHEMY_API_KEY=your-alchemy-api-key

# Resend API key for sending verification emails
# Get yours at: https://resend.com/
RESEND_API_KEY=your-resend-api-key

# JWT secret for authentication tokens
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,https://teqo.app,https://www.teqo.app,https://mycelia.solla.dev

# Server port (optional, defaults to 4000)
PORT=4000
